{
  "name": "psm",
  "private": true,
  "type": "module",
  "workspaces": [
    "src/psm-core",
    "src/psm-cli",
    "src/psm-pi-plugin",
    "benchmark/locomo"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish",
    "locomo:evaluate": "node dist/benchmark/locomo/src/evaluate.js",
    "locomo:ingest": "node dist/benchmark/locomo/src/ingest.js",
    "locomo:ingest-node": "node dist/benchmark/locomo/src/ingest-node.js"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "typescript": "^6.0.3"
  }
}
