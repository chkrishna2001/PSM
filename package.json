{
  "name": "psm",
  "private": true,
  "type": "module",
  "workspaces": [
    "src/psm-core",
    "src/psm-cli",
    "src/psm-pi-plugin",
    "benchmark/locomo"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish",
    "locomo:evaluate": "node dist/benchmark/locomo/src/evaluate.js",
    "locomo:answer-evaluate": "node dist/benchmark/locomo/src/answer-evaluate.js",
    "locomo:ingest": "node dist/benchmark/locomo/src/ingest.js",
    "locomo:ingest-node": "node dist/benchmark/locomo/src/ingest-node.js",
    "locomo:report": "node dist/benchmark/locomo/src/report.js",
    "ft:sources": "node nano-psm/data-pipeline/src/prepare-external-sources.mjs",
    "ft:inspect:local": "node nano-psm/data-pipeline/src/inspect-local-psm-sources.mjs",
    "ft:generate": "node nano-psm/data-pipeline/src/generate-dataset.mjs",
    "ft:generate:fast-mixed": "node nano-psm/data-pipeline/src/generate-fast-mixed-dataset.mjs",
    "ft:generate:local": "node nano-psm/data-pipeline/src/generate-local-psm-dataset.mjs",
    "ft:merge": "node nano-psm/data-pipeline/src/merge-datasets.mjs",
    "ft:validate": "node nano-psm/data-pipeline/src/validate-examples.mjs",
    "ft:validate:runtime": "node nano-psm/data-pipeline/src/validate-runtime-compat.mjs",
    "ft:audit": "node nano-psm/data-pipeline/src/audit-quality.mjs",
    "ft:gate": "node nano-psm/data-pipeline/src/gate-dataset.mjs",
    "ft:prepare:hf": "node nano-psm/data-pipeline/src/prepare-hf-dataset.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "typescript": "^6.0.3"
  }
}
