{
  "name": "nano-psm-debug-4m",
  "model": {
    "vocab_size": 16000,
    "max_sequence_length": 1024,
    "embedding_dim": 256,
    "encoder_layers": 4,
    "attention_heads": 4,
    "feed_forward_dim": 512,
    "dropout": 0.1
  },
  "training": {
    "batch_size": 32,
    "gradient_accumulation_steps": 1,
    "learning_rate": 0.0003,
    "weight_decay": 0.01,
    "max_steps": 2000,
    "eval_every": 250,
    "save_every": 250
  }
}

