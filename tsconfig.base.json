{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "5.0",
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@psm-memory/sdk": ["src/psm-core/src/index.ts"],
      "@psm-memory/cli": ["src/psm-cli/src/index.ts"],
      "@psm-memory/pi-plugin": ["src/psm-pi-plugin/src/index.ts"]
    }
  }
}
