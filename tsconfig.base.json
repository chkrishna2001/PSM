{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "psm-sdk": ["src/psm-core/src/index.ts"],
      "psm-cli": ["src/psm-cli/src/index.ts"],
      "psm-pi-plugin": ["src/psm-pi-plugin/src/index.ts"]
    }
  }
}
