{
  "name": "@psm-memory/cli",
  "version": "0.1.0",
  "type": "module",
  "description": "Command line interface for PSM Memory context, remember, and recall workflows.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chkrishna2001/PSM.git",
    "directory": "src/psm-cli"
  },
  "bin": {
    "psm-memory": "dist/cli.js",
    "psm": "dist/cli.js"
  },
  "scripts": {
    "postinstall": "node ./dist/install-model.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.js.map",
    "CHANGELOG.md",
    "README.md",
    "package.json"
  ],
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "@psm-memory/sdk": "0.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
